# ================================
# ElimAPP API - Variables de Entorno
# ================================

# Puerto del servidor
PORT=3001

# API Key - CÁMBIALA por una clave segura y larga
# Genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_SEGURA_LARGA_Y_ALEATORIA

# Orígenes permitidos para CORS (separados por coma)
# Deja vacío para permitir cualquier origen (solo para desarrollo)
ALLOWED_ORIGINS=

# Entorno: development | production
NODE_ENV=production

# Rate limiting - máximo de peticiones por ventana de tiempo
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100
